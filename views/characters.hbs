<h1>{{title}}</h1>
<table border="1" cellpadding="5" cellspacing="0">
  <thead>
    <tr>
      <th>Name</th>
      <th>Race</th>
      <th>Class</th>
      <th>Role</th>
      <th>Level</th>
      <th>Max HP</th>
      <th>AC</th>
      <th>Initiative Bonus</th>
      <th>Remove</th>
    </tr>
  </thead>
  <tbody>
    {{#each characters}}
      <tr>
        <td>{{displayName}}</td>
        <td>{{race}}</td>
        <td>{{characterClass}}</td>
        <td>{{characterRole}}</td>
        <td>{{characterLevel}}</td>
        <td>{{maxHitPoint}}</td>
        <td>{{armorClass}}</td>
        <td>{{initiativeBonus}}</td>
        <td>
          <form method="POST" action="/characters/delete" onsubmit="return confirm('Are you sure you want to delete this character?')">
            <input type="hidden" name="idCharactersInput" value="{{idCharacters}}">
            <button type="submit">Delete</button>
          </form>
        </td>
      </tr>
    {{/each}}
  </tbody>
</table>

{{!Our Own Work}}
<h2>Add New Character</h2>
<form method="POST" action="/characters/add">
  Name: <input type="text" name="displayNameInput" required><br>
  Race: <input type="text" name="raceInput"><br>
  Class: <input type="text" name="characterClassInput"><br>
  Role:
  <select name="characterRoleInput">
    <option value="">-- Select Role --</option>
    <option value="PC">PC</option>
    <option value="NPC">NPC</option>
  </select><br>
  Level: <input type="number" name="characterLevelInput"><br>
  Max HP: <input type="number" name="maxHitPointInput"><br>
  AC: <input type="number" name="armorClassInput"><br>
  Initiative Bonus: <input type="number" name="initiativeBonusInput"><br>
  <button type="submit">Add Character</button>
</form>

{{!Our Own Work}}
<h2>Update Character</h2>
<form method="POST" action="/characters/update">
  Name of Character:
  <select name="idCharactersInput" required>
    {{#each characters}}
      <option value="{{idCharacters}}">{{displayName}} (ID: {{idCharacters}})</option>
    {{/each}}
  </select>
  <br><br>
  Name: <input type="text" name="displayNameInput"><br>
  Race: <input type="text" name="raceInput"><br>
  Class: <input type="text" name="characterClassInput"><br>
  Role:
  <select name="characterRoleInput">
    <option value="">-- Select Role --</option>
    <option value="PC">PC</option>
    <option value="NPC">NPC</option>
  </select><br>
  Level: <input type="number" name="characterLevelInput"><br>
  Max HP: <input type="number" name="maxHitPointInput"><br>
  AC: <input type="number" name="armorClassInput"><br>
  Initiative Bonus: <input type="number" name="initiativeBonusInput"><br>
  <button type="submit">Update Character</button>
</form>


